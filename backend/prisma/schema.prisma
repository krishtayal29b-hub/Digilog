// DigiLog — Prisma schema
// Enterprise Digital Logbook for Industrial Operations
// Datasource: PostgreSQL (Neon / Railway / self-hosted)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────────────────────

enum UserRole {
  OPERATOR
  SUPERVISOR
  MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DEACTIVATED
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

enum LogStatus {
  DRAFT
  SUBMITTED
  SIGNED
  ARCHIVED
}

enum EventPriority {
  ROUTINE
  MAINTENANCE
  EMERGENCY
}

enum EventStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

enum CapaType {
  CORRECTIVE
  PREVENTIVE
}

enum CapaStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

enum HandoverStatus {
  DRAFT
  PENDING_ACK
  ACKNOWLEDGED
}

enum MachineStatus {
  RUNNING
  IDLE
  MAINTENANCE
  FAULT
  OFFLINE
}

enum NotificationType {
  INFO
  WARNING
  INCIDENT
  MENTION
  HANDOVER
  SYSTEM
}

enum TokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  SIGN
  ESCALATE
}

// ────────────────────────────────────────────────────────────
// Identity & Access
// ────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  passwordHash      String
  firstName         String
  lastName          String
  phone             String?
  avatarUrl         String?
  role              UserRole   @default(OPERATOR)
  status            UserStatus @default(ACTIVE)
  emailVerified     Boolean    @default(false)
  mfaEnabled        Boolean    @default(false)
  mfaSecret         String?
  jobTitle          String?
  lastLoginAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  departmentId      String?
  department        Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  refreshTokens     RefreshToken[]
  verificationTokens VerificationToken[]
  shiftLogs         ShiftLog[]           @relation("LogAuthor")
  eventsCreated     OperationalEvent[]   @relation("EventCreator")
  incidentsReported Incident[]           @relation("IncidentReporter")
  incidentsAssigned Incident[]           @relation("IncidentAssignee")
  capas             Capa[]               @relation("CapaOwner")
  handoversFrom     ShiftHandover[]      @relation("HandoverFrom")
  handoversTo       ShiftHandover[]      @relation("HandoverTo")
  comments          Comment[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@index([role])
  @@index([status])
  @@index([departmentId])
}

model RefreshToken {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent     String?
  ipAddress     String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model VerificationToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  type       TokenType
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, type])
}

// ────────────────────────────────────────────────────────────
// Organization
// ────────────────────────────────────────────────────────────

model Plant {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  location    String?
  timezone    String       @default("Asia/Kolkata")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  departments Department[]
  machines    Machine[]
  shiftLogs   ShiftLog[]
  incidents   Incident[]
}

model Department {
  id          String     @id @default(cuid())
  name        String
  code        String
  plantId     String
  plant       Plant      @relation(fields: [plantId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users       User[]
  machines    Machine[]
  shiftLogs   ShiftLog[]

  @@unique([plantId, code])
  @@index([plantId])
}

model Machine {
  id            String        @id @default(cuid())
  name          String
  tag           String
  type          String?
  status        MachineStatus @default(RUNNING)
  healthScore   Int           @default(100)
  plantId       String
  plant         Plant         @relation(fields: [plantId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  events        OperationalEvent[]
  incidents     Incident[]

  @@unique([plantId, tag])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
// Module 2 — Digital Shift Logbook
// ────────────────────────────────────────────────────────────

model ShiftLog {
  id              String     @id @default(cuid())
  code            String     @unique @default(cuid())
  authorId        String
  author          User       @relation("LogAuthor", fields: [authorId], references: [id])
  plantId         String
  plant           Plant      @relation(fields: [plantId], references: [id])
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  shiftType       ShiftType
  shiftDate       DateTime
  status          LogStatus  @default(DRAFT)

  equipmentStatus String?
  temperature     Float?
  pressure        Float?
  productionNotes String?
  safetyNotes     String?
  remarks         String?

  signedAt        DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  attachments     Attachment[]

  @@index([authorId])
  @@index([plantId])
  @@index([shiftDate])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
// Module 3 — Operational Events
// ────────────────────────────────────────────────────────────

model OperationalEvent {
  id          String        @id @default(cuid())
  title       String
  description String
  priority    EventPriority @default(ROUTINE)
  status      EventStatus   @default(OPEN)

  creatorId   String
  creator     User          @relation("EventCreator", fields: [creatorId], references: [id])
  machineId   String?
  machine     Machine?      @relation(fields: [machineId], references: [id], onDelete: SetNull)

  occurredAt  DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  comments    Comment[]
  attachments Attachment[]
  incident    Incident?

  @@index([priority])
  @@index([status])
  @@index([creatorId])
}

// ────────────────────────────────────────────────────────────
// Module 4 — Incident Management + CAPA
// ────────────────────────────────────────────────────────────

model Incident {
  id            String           @id @default(cuid())
  code          String           @unique @default(cuid())
  title         String
  description   String
  severity      IncidentSeverity @default(MEDIUM)
  status        IncidentStatus   @default(OPEN)
  rootCause     String?

  reporterId    String
  reporter      User             @relation("IncidentReporter", fields: [reporterId], references: [id])
  assigneeId    String?
  assignee      User?            @relation("IncidentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  plantId       String?
  plant         Plant?           @relation(fields: [plantId], references: [id], onDelete: SetNull)
  machineId     String?
  machine       Machine?         @relation(fields: [machineId], references: [id], onDelete: SetNull)
  eventId       String?          @unique
  event         OperationalEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  escalated     Boolean          @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  capas         Capa[]
  comments      Comment[]
  attachments   Attachment[]

  @@index([severity])
  @@index([status])
  @@index([reporterId])
  @@index([assigneeId])
}

model Capa {
  id          String     @id @default(cuid())
  incidentId  String
  incident    Incident   @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  type        CapaType
  action      String
  status      CapaStatus @default(OPEN)
  ownerId     String?
  owner       User?      @relation("CapaOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([incidentId])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
// Module 5 — Shift Handover
// ────────────────────────────────────────────────────────────

model ShiftHandover {
  id             String         @id @default(cuid())
  code           String         @unique @default(cuid())
  fromUserId     String
  fromUser       User           @relation("HandoverFrom", fields: [fromUserId], references: [id])
  toUserId       String?
  toUser         User?          @relation("HandoverTo", fields: [toUserId], references: [id], onDelete: SetNull)

  shiftType      ShiftType
  shiftDate      DateTime
  status         HandoverStatus @default(DRAFT)

  summary        String?
  pendingWork    String?
  supervisorNote String?
  checklist      Json?

  signatureData  String?
  signedAt       DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([fromUserId])
  @@index([shiftDate])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
// Cross-cutting — Comments, Attachments, Notifications, Audit
// ────────────────────────────────────────────────────────────

model Comment {
  id         String            @id @default(cuid())
  body       String
  authorId   String
  author     User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mentions   String[]          @default([])

  eventId    String?
  event      OperationalEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  incidentId String?
  incident   Incident?         @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([eventId])
  @@index([incidentId])
}

model Attachment {
  id           String            @id @default(cuid())
  fileName     String
  url          String
  mimeType     String
  sizeBytes    Int
  uploadedById String

  shiftLogId   String?
  shiftLog     ShiftLog?         @relation(fields: [shiftLogId], references: [id], onDelete: Cascade)
  eventId      String?
  event        OperationalEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  incidentId   String?
  incident     Incident?         @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  createdAt    DateTime          @default(now())

  @@index([shiftLogId])
  @@index([eventId])
  @@index([incidentId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(INFO)
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
