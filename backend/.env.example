# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────
# Local docker-compose default, or a Neon/Railway connection string.
DATABASE_URL=postgresql://digilog:digilog@localhost:5432/digilog?schema=public

# ── JWT ───────────────────────────────────────────────────
# Generate strong secrets, e.g.  openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-at-least-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-16-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Set when frontend & API share a parent domain in production (e.g. .digilog.app)
# COOKIE_DOMAIN=

# ── Email (optional in dev; logs to console if unset) ─────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=DigiLog <no-reply@digilog.app>

# ── Rate limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── File storage (optional in dev; falls back to local ./uploads) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_UPLOAD_MB=10
